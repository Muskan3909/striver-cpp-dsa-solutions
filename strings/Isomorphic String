class Solution {
public:
    bool isomorphicString(string s1, string s2) {
    	int m1[256] = {0}, m2[256] = {0}; 
        
        int n = s1.size(); 
        for (int i = 0; i < n; ++i) {
            if (m1[s1[i]] != m2[s2[i]]) return false;
            m1[s1[i]] = i + 1;
            m2[s2[i]] = i + 1;
        }
        return true;
    }
};
   
