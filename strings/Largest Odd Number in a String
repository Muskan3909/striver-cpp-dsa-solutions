class Solution{	
public:		
    string largeOddNum(string& s){
        //your code goes here
        int ind = -1;
        for(int i = s.length() - 1; i>=0; i--){
            if((s[i] - '0') % 2 == 1){
                ind=i;
                break;
            }
        }
        if(ind == -1) return "";
        int i = 0;
        while(i< s.length()){
            if(s[i] != '0') break;
            i++;
        }
return s.substr(i,ind - i+1);
    }
};
